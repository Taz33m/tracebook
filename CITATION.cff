    email: "tazeemmahashin@gmail.com"
version: "0.5.0"
date-released: 2026-07-19
license: MIT
repository-code: "https://github.com/Taz33m/tracebook"
url: "https://pypi.org/project/tracebook-sim/0.5.0/"
keywords:
  - matching engine
  - conformance testing
  - differential testing
  - delta debugging
  - market microstructure
  - limit order book
